        {
          "name": "Create Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced React Development\",\n  \"description\": \"Master advanced React concepts including hooks, context, performance optimization, and modern patterns. Build production-ready applications with best practices.\",\n  \"shortDescription\": \"Advanced React development course covering hooks, context, and optimization.\",\n  \"category\": \"web-development\",\n  \"subcategory\": \"react\",\n  \"level\": \"advanced\",\n  \"price\": 199.99,\n  \"currency\": \"USD\",\n  \"duration\": 50,\n  \"thumbnail\": \"https://example.com/course-thumbnail.jpg\",\n  \"tags\": [\"react\", \"javascript\", \"hooks\", \"advanced\"],\n  \"prerequisites\": [\n    \"Strong JavaScript knowledge\",\n    \"Basic React experience\",\n    \"Understanding of ES6+\"\n  ],\n  \"learningObjectives\": [\n    \"Master React hooks and custom hooks\",\n    \"Implement advanced state management\",\n    \"Optimize React application performance\",\n    \"Build scalable React applications\"\n  ],\n  \"targetAudience\": [\n    \"Experienced React developers\",\n    \"Frontend developers seeking advanced skills\"\n  ],\n  \"requirements\": [\n    \"React development experience\",\n    \"Node.js and npm installed\",\n    \"Code editor (VS Code recommended)\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/courses",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "courses"]
            },
            "description": "Create a new course (Instructor or Admin only).\n\n**Required Fields:**\n- title: Course title (5-100 characters)\n- description: Detailed description (50-2000 characters)\n- shortDescription: Brief description (20-200 characters)\n- category: Course category\n- level: beginner, intermediate, advanced\n- price: Course price (0 for free)\n- duration: Course duration in hours\n- learningObjectives: Array of learning objectives\n\n**Authentication:**\n- Requires instructor or admin role\n- Course is automatically assigned to the authenticated user"
          },
          "response": []
        },
