              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful\",\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"_id\": \"507f1f77bcf86cd799439011\",\n    \"firstName\": \"Jane\",\n    \"lastName\": \"Student\",\n    \"email\": \"student@lms.com\",\n    \"role\": \"student\",\n    \"isActive\": true,\n    \"lastLogin\": \"2024-01-15T10:30:00.000Z\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Current User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "me"]
            },
            "description": "Get the current authenticated user's profile information.\n\n**Authentication Required:**\n- Include JWT token in Authorization header\n\n**Response:**\n- Complete user profile\n- Enrolled courses (for students)\n- Created courses (for instructors)"
          },
          "response": []
        },
        {
          "name": "Update User Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Updated\",\n  \"bio\": \"Updated bio information\",\n  \"phoneNumber\": \"+1234567890\",\n  \"preferences\": {\n    \"notifications\": {\n      \"email\": true,\n      \"push\": false\n    },\n    \"language\": \"en\",\n    \"timezone\": \"UTC\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/update-profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "update-profile"]
            },
            "description": "Update user profile information.\n\n**Optional Fields:**\n- firstName, lastName, bio, phoneNumber\n- dateOfBirth, address, socialLinks\n- preferences (notifications, language, timezone)\n\n**Note:** Email and role cannot be updated through this endpoint."
          },
          "response": []
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"OldPassword123!\",\n  \"newPassword\": \"NewSecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "change-password"]
            },
            "description": "Change user password.\n\n**Required Fields:**\n- currentPassword: User's current password\n- newPassword: New password (minimum 6 characters with uppercase, lowercase, and number)\n\n**Security:**\n- Current password must be verified\n- New password is hashed before storage"
          },
          "response": []
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/verify-token",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "verify-token"]
            },
            "description": "Verify if the provided JWT token is valid.\n\n**Use Cases:**\n- Check token validity before making requests\n- Validate user session\n- Frontend token verification"
          },
          "response": []
        },
        {
          "name": "Logout User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            },
            "description": "Logout user (client-side token removal).\n\n**Note:**\n- In stateless JWT implementation, logout is primarily client-side\n- Server logs the logout event\n- Client should remove token from storage"
          },
          "response": []
        }
      ]
    },
